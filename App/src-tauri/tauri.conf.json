{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ORCA",
  "version": "0.1.0",
  "identifier": "com.orca.project",
  "build": {
    "beforeDevCommand": {
      "cwd": "..",
      "script": "pnpm dev",
      "wait": false
    },
    "devUrl": "http://localhost:7777",
    "beforeBuildCommand": {
      "cwd": "..",
      "script": "pnpm build"
    },
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ORCA",
        "decorations": false,
        "width": 1200,
        "height": 760,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
