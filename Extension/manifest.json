{
  "manifest_version": 3,
  "name": "CyberBase Web Guard",
  "version": "1.0",
  "description": "Silent navigation security, DLP, and real-time employee security training for CyberBase.",
  "permissions": ["storage", "alarms", "scripting", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/sweetalert2.all.min.js",
        "lib/pdf.min.js",
        "lib/mammoth.browser.min.js",
        "content.js"
      ],
      "css": ["custom.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "lib/pdf.worker.min.js",
        "lib/transformers.min.js",
        "lib/ort-wasm.wasm",
        "lib/ort-wasm-threaded.wasm",
        "lib/ort-wasm-simd.wasm",
        "lib/ort-wasm-simd-threaded.wasm"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
